#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_install:
	# Perl module
	install -D -m 0644 src/PVE/API2/Hardware/XPU.pm \
		$(CURDIR)/debian/pve-gpu-manager/usr/share/perl5/PVE/API2/Hardware/XPU.pm
	# JavaScript plugin
	install -D -m 0644 src/js/pve-xpu-plugin.js \
		$(CURDIR)/debian/pve-gpu-manager/usr/share/pve-manager/js/pve-xpu-plugin.js
	# Scripts
	install -D -m 0755 src/scripts/apply-sriov-config.sh \
		$(CURDIR)/debian/pve-gpu-manager/usr/lib/pve-xpu/apply-sriov-config.sh
	install -D -m 0755 src/scripts/apply-vfio-config.sh \
		$(CURDIR)/debian/pve-gpu-manager/usr/lib/pve-xpu/apply-vfio-config.sh
	install -D -m 0755 src/scripts/reapply-patches.sh \
		$(CURDIR)/debian/pve-gpu-manager/usr/lib/pve-xpu/reapply-patches.sh
	# Systemd service
	install -D -m 0644 src/systemd/pve-xpu-sriov.service \
		$(CURDIR)/debian/pve-gpu-manager/lib/systemd/system/pve-xpu-sriov.service
	install -D -m 0644 src/systemd/pve-xpu-vfio.service \
		$(CURDIR)/debian/pve-gpu-manager/lib/systemd/system/pve-xpu-vfio.service
	# Default templates (staged; postinst copies to /etc/pve/local/)
	install -D -m 0644 config/xpu-vf-templates.conf \
		$(CURDIR)/debian/pve-gpu-manager/usr/share/pve-xpu/xpu-vf-templates.conf
	# APT hook
	install -D -m 0644 config/99-pve-xpu-reapply \
		$(CURDIR)/debian/pve-gpu-manager/etc/apt/apt.conf.d/99-pve-xpu-reapply
